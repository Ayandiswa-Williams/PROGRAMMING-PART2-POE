
<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="700" Width="900"
        Background="#0A1428" Foreground="#00FFCC" FontFamily="Consolas">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat Area -->
            <RowDefinition Height="Auto"/>
            <!-- Input -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E2A44" Padding="15">
            <StackPanel>
                <TextBlock Text="CYBERSECURITY AWARENESS BOT" 
                           FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#00FFCC"/>
                <TextBlock x:Name="AsciiArt" TextWrapping="Wrap" FontSize="10" 
                           HorizontalAlignment="Center" Margin="10" Foreground="#00CCFF"/>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" 
                      Background="#112233" Margin="10">
            <TextBlock x:Name="ChatDisplay" TextWrapping="Wrap" Padding="15" 
                       FontSize="14" Foreground="#E0F0FF"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Grid Grid.Row="2" Background="#1E2A44" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserInput" Grid.Column="0" Height="45" Margin="5"
                     Background="#223355" Foreground="#FFFFFF" FontSize="16"
                     VerticalContentAlignment="Center" KeyDown="UserInput_KeyDown"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="SEND" Width="100" 
                    Height="45" Margin="5" Click="SendButton_Click"
                    Background="#00FFCC" Foreground="#0A1428" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
